{
  "name": "camox",
  "version": "0.2.0-alpha.2",
  "files": [
    "dist",
    "server",
    "skills"
  ],
  "type": "module",
  "exports": {
    "./createApp": {
      "source": "./src/core/createApp.ts",
      "types": "./dist/core/createApp.d.ts",
      "import": "./dist/core/createApp.js"
    },
    "./createBlock": {
      "source": "./src/core/createBlock.tsx",
      "types": "./dist/core/createBlock.d.ts",
      "import": "./dist/core/createBlock.js"
    },
    "./createLayout": {
      "source": "./src/core/createLayout.tsx",
      "types": "./dist/core/createLayout.d.ts",
      "import": "./dist/core/createLayout.js"
    },
    "./CamoxPreview": {
      "source": "./src/features/preview/CamoxPreview.tsx",
      "types": "./dist/features/preview/CamoxPreview.d.ts",
      "import": "./dist/features/preview/CamoxPreview.js"
    },
    "./CamoxContent": {
      "source": "./src/features/content/CamoxContent.tsx",
      "types": "./dist/features/content/CamoxContent.d.ts",
      "import": "./dist/features/content/CamoxContent.js"
    },
    "./CamoxProvider": {
      "source": "./src/features/provider/CamoxProvider.tsx",
      "types": "./dist/features/provider/CamoxProvider.d.ts",
      "import": "./dist/features/provider/CamoxProvider.js"
    },
    "./CamoxStudio": {
      "source": "./src/features/studio/CamoxStudio.tsx",
      "types": "./dist/features/studio/CamoxStudio.d.ts",
      "import": "./dist/features/studio/CamoxStudio.js"
    },
    "./vite": {
      "source": "./src/features/vite/vite.ts",
      "types": "./dist/features/vite/vite.d.ts",
      "import": "./dist/features/vite/vite.js"
    },
    "./server/api": {
      "types": "./server/api.d.ts",
      "default": "./server/api.js"
    },
    "./server/dataModel": {
      "types": "./server/dataModel.d.ts",
      "default": "./server/dataModel.js"
    },
    "./_internal/pageRoute": {
      "source": "./src/features/routes/pageRoute.tsx",
      "types": "./dist/features/routes/pageRoute.d.ts",
      "import": "./dist/features/routes/pageRoute.js"
    },
    "./_internal/ogRoute": {
      "source": "./src/features/routes/ogRoute.ts",
      "types": "./dist/features/routes/ogRoute.d.ts",
      "import": "./dist/features/routes/ogRoute.js"
    },
    "./studio.css": "./dist/studio.css"
  },
  "scripts": {
    "dev": "tailwindcss -i ./src/studio.css -o ./dist/studio.css --watch",
    "build:css": "tailwindcss -i ./src/studio.css -o ./dist/studio.css --minify",
    "build": "vite build && pnpm build:css",
    "build:watch": "vite build --watch",
    "lint": "oxlint",
    "check": "tsgo --noEmit && oxlint --fix"
  },
  "dependencies": {
    "@camox/backend-content": "workspace:*",
    "@camox/ui": "workspace:*",
    "@convex-dev/better-auth": "^0.11.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lexical/markdown": "^0.41.0",
    "@lexical/react": "^0.41.0",
    "@lexical/rich-text": "^0.41.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-slot": "^1.2.3",
    "@sinclair/typebox": "^0.34.41",
    "@takumi-rs/image-response": "^0.70.4",
    "@tanstack/react-form": "^1.28.4",
    "@xstate/store": "^3.9.2",
    "better-auth": "^1.5.5",
    "convex": "^1.32.0",
    "fractional-indexing": "^3.2.0",
    "lexical": "^0.41.0",
    "lucide-react": "^0.476.0",
    "posthog-js": "^1.363.4",
    "posthog-node": "^5.28.5",
    "react": "19.3.0-canary-8b2e903a-20260320",
    "react-dom": "19.3.0-canary-8b2e903a-20260320",
    "react-og-preview": "^0.2.0",
    "shiki": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.6",
    "@types/node": "^24.6.2",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.1.9",
    "@typescript/native-preview": "^7.0.0-dev",
    "@vitejs/plugin-react": "^6.0.1",
    "oxlint": "^0.15.0",
    "tailwindcss": "^4.0.6",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5.7.2",
    "vite": "8.0.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "@tanstack/react-router": "^1.166.2",
    "@tanstack/react-start": "^1.166.2"
  }
}
