{
  "name": "camox-monorepo",
  "version": "0.2.0-alpha.2",
  "private": true,
  "author": "",
  "scripts": {
    "build": "nx run-many -t build --all",
    "dev": "nx run-many -t dev --all --parallel=10",
    "lint": "nx run-many -t lint --all",
    "test": "nx run-many -t test --all",
    "fmt": "oxfmt .",
    "check": "oxfmt . && nx run-many -t check --all --no-tui",
    "seed": "pnpm -F @camox/backend-content exec convex run seed:seedWebsite && pnpm -F @camox/backend-management exec convex run seed:seedProjects",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@typescript/native-preview": "^7.0.0-dev",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.0",
    "nx": "^21.6.3",
    "oxfmt": "^0.38.0"
  },
  "lint-staged": {
    "*": [
      "oxfmt",
      "nx affected -t check"
    ]
  },
  "packageManager": "pnpm@10.18.1",
  "pnpm": {
    "overrides": {
      "react": "19.3.0-canary-8b2e903a-20260320",
      "react-dom": "19.3.0-canary-8b2e903a-20260320"
    }
  }
}
